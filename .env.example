# Zkopírujte tento soubor jako .env a upravte hodnoty

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=raiffeisenbank_docs

# ─── LLM Backend ─────────────────────────────────────────────────────────────
# "ollama" = lokální inference | "anthropic" | "gemini" | "openai"
LLM_BACKEND=ollama

# ─── Ollama ──────────────────────────────────────────────────────────────────
# Embeddings vždy přes Ollama (nomic-embed-text).
# LLM model se používá pouze pokud LLM_BACKEND=ollama.
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2
EMBED_MODEL=nomic-embed-text

# ─── Anthropic API ───────────────────────────────────────────────────────────
# Aktivní pouze pokud LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── Google Gemini API ───────────────────────────────────────────────────────
# Aktivní pouze pokud LLM_BACKEND=gemini
# Klíč získáte zdarma na: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# ─── OpenAI Chat API ─────────────────────────────────────────────────────────
# Aktivní pouze pokud LLM_BACKEND=openai
# API klíč je sdílený s embedding backendem.
OPENAI_API_KEY=sk-proj-...
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_CHAT_FALLBACK_MODEL=gpt-4o-mini

# ─── LLM timeouty ────────────────────────────────────────────────────────────
LLM_TIMEOUT=20
LLM_MAX_RETRIES=1
OPENAI_EMBED_TIMEOUT_SECONDS=15

# ─── Reranker ────────────────────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Nastavte "cuda" pokud máte GPU
RERANKER_DEVICE=cpu

# ─── Chunking ────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ─── LLM generování ──────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
