# Zkopírujte tento soubor jako .env a upravte hodnoty

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=raiffeisenbank_docs

# ─── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=mistral
EMBED_MODEL=nomic-embed-text

# ─── Reranker ────────────────────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Nastavte "cuda" pokud máte GPU
RERANKER_DEVICE=cpu

# ─── Chunking ────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ─── LLM generování ──────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
