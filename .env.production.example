# Production example for RB Banking RAG
# Copy to .env and fill secrets. Do not commit real values.

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=raiffeisenbank_docs

LLM_BACKEND=openai
OPENAI_API_KEY=sk-proj-CHANGE_ME
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_CHAT_FALLBACK_MODEL=gpt-4o-mini

LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
RERANKER_DEVICE=cpu

# Frontend build/runtime API URL. Use your public backend URL in production.
VITE_API_URL=https://api.example.com

# Keep false unless intentionally debugging internal retrieval metadata.
DEBUG_API_ERRORS=false
